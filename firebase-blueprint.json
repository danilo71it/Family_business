{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "groupId": { "type": "string", "description": "ID of the family group the user belongs to" }
      },
      "required": ["uid", "email"]
    },
      "Transaction": {
      "title": "Transaction",
      "description": "Financial income or expense record",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "amount": { "type": "number" },
        "type": { "type": "string", "enum": ["income", "expense", "appointment", "note"] },
        "category": { "type": "string" },
        "description": { "type": "string" },
        "note": { "type": "string" },
        "address": { "type": "string" },
        "time": { "type": "string" },
        "reminders": { 
          "type": "array", 
          "items": { 
            "type": "object", 
            "properties": {
              "value": { "type": "number" },
              "unit": { "type": "string", "enum": ["minutes", "hours", "days"] }
            }
          }
        },
        "date": { "type": "string", "format": "date-time" },
        "userId": { "type": "string" },
        "groupId": { "type": "string" },
        "isUnknownAmount": { "type": "boolean" },
        "isPrivacyActive": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "isEstimate": { "type": "boolean" },
        "recurring": { "type": "boolean" },
        "frequency": { "type": "string", "enum": ["daily", "weekly", "monthly", "yearly"] },
        "occurrenceCount": { "type": "number" },
        "reminderEnabled": { "type": "boolean" },
        "parentTransactionId": { "type": "string" }
      },
      "required": ["amount", "type", "category", "date", "userId", "groupId", "isEstimate", "recurring", "reminderEnabled"]
    },
    "FamilyGroup": {
      "title": "FamilyGroup",
      "description": "A group representing a family or household ledger",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "ownerId": { "type": "string" },
        "members": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["name", "ownerId"]
    },
    "WorkShift": {
      "title": "WorkShift",
      "description": "Definition of a shift type",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "color": { "type": "string" }
      },
      "required": ["name", "color"]
    },
    "ShiftCycle": {
      "title": "ShiftCycle",
      "description": "The sequence and start date of shifts",
      "type": "object",
      "properties": {
        "shiftIds": { "type": "array", "items": { "type": "string" } },
        "startDate": { "type": "string", "format": "date-time" }
      },
      "required": ["shiftIds", "startDate"]
    },
    "ShiftOverride": {
      "title": "ShiftOverride",
      "description": "Manual override for a specific day's shift",
      "type": "object",
      "properties": {
        "date": { "type": "string", "format": "date-time" },
        "shiftId": { "type": "string" }
      },
      "required": ["date"]
    },
    "PushSubscription": {
      "title": "PushSubscription",
      "description": "Web Push API subscription object",
      "type": "object",
      "properties": {
        "subscription": { "type": "object" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "userAgent": { "type": "string" }
      },
      "required": ["subscription"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "Global user profiles"
    },
    "users/{userId}/push_subscriptions/{subId}": {
      "schema": "PushSubscription",
      "description": "User push notification subscriptions"
    },
    "groups/{groupId}": {
      "schema": "FamilyGroup",
      "description": "Family group definitions"
    },
    "groups/{groupId}/transactions/{transactionId}": {
      "schema": "Transaction",
      "description": "Ledger entries for a specific group"
    },
    "groups/{groupId}/shifts/{shiftId}": {
      "schema": "WorkShift",
      "description": "Shift definitions for the group"
    },
    "groups/{groupId}/config/shiftCycle": {
      "schema": "ShiftCycle",
      "description": "The shift cycle configuration"
    },
    "groups/{groupId}/shiftOverrides/{overrideId}": {
      "schema": "ShiftOverride",
      "description": "Manual shift overrides"
    }
  }
}
