rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    
    function isValidId(id) { 
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }

    function isGroupMember(groupId) {
      return isSignedIn() && exists(/databases/$(database)/documents/groups/$(groupId)) &&
             request.auth.uid in get(/databases/$(database)/documents/groups/$(groupId)).data.members;
    }

    // User Profile Rules
    match /users/{userId} {
      function isValidUser(data) {
        return data.uid == userId &&
               data.email is string && data.email.size() <= 256 &&
               (data.displayName == null || (data.displayName is string && data.displayName.size() <= 128)) &&
               (data.photoURL == null || (data.photoURL is string && data.photoURL.size() <= 512)) &&
               (data.groupId == null || (data.groupId is string && data.groupId.size() <= 128));
      }

      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && isValidUser(incoming()) && 
                    incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'groupId']);
    }

    // Group Rules
    match /groups/{groupId} {
      function isValidGroup(data) {
        return data.name is string && data.name.size() <= 100 &&
               data.ownerId == request.auth.uid &&
               data.members is list && data.members.size() <= 50 &&
               request.auth.uid in data.members;
      }

      allow get: if isSignedIn() && (request.auth.uid in existing().members);
      allow create: if isSignedIn() && isValidId(groupId) && isValidGroup(incoming());
      allow update: if isSignedIn() && (request.auth.uid == existing().ownerId) && isValidGroup(incoming()) &&
                    incoming().diff(existing()).affectedKeys().hasOnly(['name', 'members']);
      allow delete: if isSignedIn() && (request.auth.uid == existing().ownerId);

      // Transactions subcollection
      match /transactions/{transactionId} {
        function isValidTransaction(data) {
          return data.amount is number &&
                 data.type in ['income', 'expense'] &&
                 data.category is string && data.category.size() <= 50 &&
                 data.description is string && data.description.size() <= 1000 &&
                 data.date is timestamp &&
                 data.userId == request.auth.uid &&
                 data.groupId == groupId &&
                 data.createdAt == request.time &&
                 data.updatedAt == request.time;
        }

        allow list: if isGroupMember(groupId) && resource.data.groupId == groupId;
        allow get: if isGroupMember(groupId);
        allow create: if isGroupMember(groupId) && isValidId(transactionId) && isValidTransaction(incoming());
        allow update: if isGroupMember(groupId) && incoming().userId == existing().userId &&
                      isValidTransaction(incoming()) && incoming().createdAt == existing().createdAt &&
                      incoming().updatedAt == request.time &&
                      incoming().diff(existing()).affectedKeys().hasOnly(['amount', 'type', 'category', 'description', 'date', 'updatedAt']);
        allow delete: if isGroupMember(groupId) && (request.auth.uid == existing().userId || get(/databases/$(database)/documents/groups/$(groupId)).data.ownerId == request.auth.uid);
      }
    }
  }
}
