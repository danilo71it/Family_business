rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    
    function isValidId(id) { 
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }

    function isGroupMember(groupId) {
      return isSignedIn() && 
        exists(/databases/$(database)/documents/groups/$(groupId)) &&
        request.auth.uid in get(/databases/$(database)/documents/groups/$(groupId)).data.members;
    }

    // User Profile Rules
    match /users/{userId} {
      function isValidUser(data) {
        return data.uid == userId &&
               data.email is string && data.email.size() <= 256 &&
               (data.displayName == null || (data.displayName is string && data.displayName.size() <= 128)) &&
               (data.photoURL == null || (data.photoURL is string && data.photoURL.size() <= 512)) &&
               (data.groupId == null || (data.groupId is string && data.groupId.size() <= 128));
      }

      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && isValidUser(incoming()) && 
                    incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'groupId']);
    }

    // Group Rules
    match /groups/{groupId} {
      function isValidGroup(data) {
        return data.name is string && data.name.size() <= 100 &&
               data.ownerId == request.auth.uid &&
               data.members is list && data.members.size() <= 50 &&
               request.auth.uid in data.members;
      }

      allow get: if isSignedIn() && (request.auth.uid in existing().members);
      allow create: if isSignedIn() && isValidId(groupId) && isValidGroup(incoming());
      allow update: if isSignedIn() && (request.auth.uid == existing().ownerId) && isValidGroup(incoming()) &&
                    incoming().diff(existing()).affectedKeys().hasOnly(['name', 'members']);
      allow delete: if isSignedIn() && (request.auth.uid == existing().ownerId);

      // Transactions subcollection
      match /transactions/{transactionId} {
        function isValidTransaction(data) {
          return data.amount is number &&
                 data.type in ['income', 'expense', 'appointment', 'note'] &&
                 data.category is string &&
                 data.date is timestamp &&
                 data.userId is string &&
                 data.groupId == groupId &&
                 data.isEstimate is bool &&
                 data.recurring is bool &&
                 data.reminderEnabled is bool &&
                 (data.get('isUnknownAmount', null) == null || data.isUnknownAmount is bool) &&
                 (data.get('isPrivacyActive', null) == null || data.isPrivacyActive is bool) &&
                 (data.get('description', null) == null || data.description is string) &&
                 (data.get('note', null) == null || data.note is string) &&
                 (data.get('address', null) == null || data.address is string) &&
                 (data.get('time', null) == null || data.time is string) &&
                 (data.get('reminders', null) == null || data.reminders is list) &&
                 (data.get('frequency', null) == null || data.frequency == "" || data.frequency in ['daily', 'weekly', 'monthly', 'yearly']) &&
                 (data.get('occurrenceCount', null) == null || data.occurrenceCount is number) &&
                 (data.get('parentTransactionId', null) == null || data.parentTransactionId is string);
        }

        allow list: if isGroupMember(groupId);
        allow get: if isGroupMember(groupId);
        allow create: if isGroupMember(groupId) && isValidTransaction(incoming());
        allow update: if isGroupMember(groupId) && isValidTransaction(incoming());
        allow delete: if isGroupMember(groupId);
      }

      // Shifts definition
      match /shifts/{shiftId} {
        allow read: if isGroupMember(groupId);
        allow write: if isGroupMember(groupId);
      }

      // Shift Cycle config
      match /config/shiftCycle {
        allow read: if isGroupMember(groupId);
        allow write: if isGroupMember(groupId);
      }

      // Shift Overrides
      match /shiftOverrides/{overrideId} {
        allow read: if isGroupMember(groupId);
        allow write: if isGroupMember(groupId);
      }
    }
  }
}
